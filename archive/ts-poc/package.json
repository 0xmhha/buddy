  },
  "keywords": [
    "claude-code",
    "hooks",
    "observability",
    "harness-engineering"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wm-it-22-00661/buddy.git"
