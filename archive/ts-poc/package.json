{
  "name": "cc-buddy-cli",
  "version": "0.0.1",
  "description": "Buddy — Claude Code 옆에서 hook 신뢰성·세션 상태를 지켜주는 친구.",
  "type": "module",
  "bin": {
    "buddy": "./dist/cli.js"
  },
  "main": "./dist/index.js",
